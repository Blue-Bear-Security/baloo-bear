# GitHub App Configuration
GITHUB_APP_ID=your_app_id_here
# Recommended: keep the private key file in .secrets/ and point to it here.
GITHUB_PRIVATE_KEY=.secrets/your-github-app.private-key.pem
# Or inline the PEM contents directly:
# GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYour private key here...\n-----END RSA PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# LLM Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Application Configuration
APP_ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
MAX_CONCURRENT_REVIEWS=3
REVIEW_STALE_TIMEOUT_MINUTES=30

# Agent Configuration (short names: flash, haiku, sonnet, gemini-pro, opus)
AGENT_PROVIDER=anthropic
AGENT_MODEL=sonnet
AGENT_FALLBACK_MODEL=google/gemini-2.5-flash
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.2
PI_BINARY_PATH=pi
PI_THINKING_LEVEL=medium

# Review Configuration
TICKET_ID_PREFIX=PROJ
REVIEW_AUTO_APPROVE=false
REVIEW_MIN_SEVERITY=MEDIUM
REVIEW_USE_CHECKS_API=true

# Database Configuration
DATABASE_ENABLED=false
# Required when DATABASE_ENABLED=true. docker compose provides a default; for local dev set this explicitly.
# Example: DATABASE_URL=postgresql+asyncpg://baloo:baloo@localhost:5432/baloo
DATABASE_URL=
POSTGRES_USER=baloo
POSTGRES_PASSWORD=change-me-before-running
POSTGRES_DB=baloo
# Optional: set to your GitHub installation ID to scope all DB queries to this tenant.
# Required when multiple Baloo instances share the same database.
INSTALLATION_ID=

# Dashboard Configuration
DASHBOARD_ENABLED=true
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
LOG_RETENTION_DAYS=30

# FP Verification Configuration
FP_VERIFICATION_ENABLED=true
FP_VERIFICATION_MODEL=haiku
FP_VERIFICATION_MAX_CONCURRENT=5
FP_AUDIT_LOG_PATH=/var/log/baloo/fp-audit.jsonl

# Thread Agent Configuration
THREAD_AGENT_ENABLED=false
THREAD_AGENT_MODEL=haiku
THREAD_AGENT_MAX_REPLIES=3
THREAD_AGENT_MAX_CONCURRENT=3

# Feedback Signals Configuration
FEEDBACK_SIGNALS_ENABLED=true
FEEDBACK_SIGNALS_TTL_DAYS=180

# AST Tools Configuration
AST_TOOLS_ENABLED=true

# Repo Provisioning Configuration
REPO_CACHE_ENABLED=true
REPO_CACHE_ROOT=/tmp/baloo-repo-cache
REPO_CACHE_MAX_DISK_GB=10
# 'bwrap' sandboxes the agent subprocess (needs bubblewrap + unprivileged user namespaces);
# falls back to 'off' automatically when unavailable.
REPO_SANDBOX_MODE=bwrap

# Documentation Drift Configuration
DOCUMENTATION_DRIFT_ENABLED=false
DOCUMENTATION_DRIFT_CATALOG_PATH=.baloo/documentation-catalog.json
DOCUMENTATION_DRIFT_MODEL=sonnet

# Fidelity Configuration
FIDELITY_ENABLED=true
FIDELITY_PLAN_PATH_PATTERN=docs/plans/{ticket_id}.md
FIDELITY_APPROVAL_THRESHOLD=90
